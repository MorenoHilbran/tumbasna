# ───────────────────────────────────────────────────────────
#  Supabase Connection (ganti dengan credential dari dashboard Supabase kamu)
#  Cara dapat: Supabase Dashboard > Project Settings > Database > Connection string
# ───────────────────────────────────────────────────────────

# Transaction Pooler (untuk Next.js / serverless — pakai port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection (untuk Prisma migrate — pakai port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ───────────────────────────────────────────────────────────
#  API Keys
# ───────────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"
FONNTE_TOKEN="your_fonnte_token"
NEXT_PUBLIC_BASE_URL=https://domainmu.com

# Supabase client (opsional, untuk pakai Supabase client langsung)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"