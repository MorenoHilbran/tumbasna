generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  phoneNumber  String         @unique @map("phone_number")
  name         String?
  email        String?        @unique
  role         user_role      @default(PETANI)
  address      String?
  businessName String?        @map("business_name")
  businessType String?        @map("business_type")
  bankName     String?        @map("bank_name")
  bankAccount  String?        @map("bank_account")
  balance      Decimal        @default(0) @db.Decimal(15, 2)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  productEntries ProductEntry[]
  orders       Order[]
  chatMessages ChatMessage[]

  @@map("users")
}

model ProductEntry {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  type            entry_type
  commodity       String
  qty             Decimal      @db.Decimal(12, 2)
  price           Decimal      @db.Decimal(12, 2)
  location        String
  lat             Float?
  lng             Float?
  status          entry_status @default(ACTIVE)
  image           String?
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  matchesAsDemand Match[]      @relation("DemandMatch")
  matchesAsSupply Match[]      @relation("SupplyMatch")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@map("product_entries")
}

model Match {
  id            String       @id @default(uuid()) @db.Uuid
  code          String?      @unique
  supplyEntryId String       @map("supply_entry_id") @db.Uuid
  demandEntryId String       @map("demand_entry_id") @db.Uuid
  status        match_status @default(PENDING)
  notifiedAt    DateTime?    @map("notified_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  demandEntry   ProductEntry @relation("DemandMatch", fields: [demandEntryId], references: [id], onDelete: Cascade)
  supplyEntry   ProductEntry @relation("SupplyMatch", fields: [supplyEntryId], references: [id], onDelete: Cascade)

  @@map("matches")
}

model ChatSession {
  phoneNumber   String   @id @map("phone_number")
  history       Json     @default("[]")
  isWhitelisted Boolean  @default(false) @map("is_whitelisted")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("chat_sessions")
}

// ── Tabel khusus untuk mobile app ──────────────────────────────

model Order {
  id               String       @id  // TRX-xxxxxx
  buyerUserId      String?      @map("buyer_user_id") @db.Uuid
  supplierName     String       @map("supplier_name")
  supplierLocation String       @map("supplier_location")
  courier          String
  shippingCost     Decimal      @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  totalAmount      Decimal      @default(0) @map("total_amount") @db.Decimal(12, 2)
  status           order_status @default(MENUNGGU_PEMBAYARAN)
  paymentQrCode    String?      @map("payment_qr_code")
  fundsReleased    Boolean      @default(false) @map("funds_released")
  notes            String?
  trackingTimeline Json         @default("[]") @map("tracking_timeline")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  buyer            User?        @relation(fields: [buyerUserId], references: [id], onDelete: SetNull)
  items            OrderItem[]
  payment          Payment?
  review           Review?
  deliveryDate     DateTime?    @map("delivery_date") @db.Date
  deliveryTimeSlot String?      @map("delivery_time_slot") @db.VarChar(50)
  buyerAddress     String?      @map("buyer_address")
  buyerPhone       String?      @map("buyer_phone") @db.VarChar(20)
  buyerCity        String?      @map("buyer_city") @db.VarChar(100)
  supplierCity     String?      @map("supplier_city") @db.VarChar(100)
  shippingZone     String?      @map("shipping_zone") @db.VarChar(50)
  paymentGroupId   String?      @map("payment_group_id") @db.Uuid
  paymentGroup     PaymentGroup? @relation(fields: [paymentGroupId], references: [id], onDelete: SetNull)

  @@map("orders")
}

model OrderItem {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @map("order_id")
  productEntryId  String?       @map("product_entry_id") @db.Uuid
  commodity       String
  price           Decimal       @db.Decimal(12, 2)
  qty             Decimal       @db.Decimal(12, 2)
  supplierName    String        @map("supplier_name")
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productEntry    ProductEntry? @relation(fields: [productEntryId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Payment {
  id              String         @id @default(uuid()) @db.Uuid
  orderId         String         @unique @map("order_id")
  midtransOrderId String         @unique @map("midtrans_order_id")
  transactionId   String?        @map("transaction_id")
  paymentType     String?        @map("payment_type")
  grossAmount     Decimal        @db.Decimal(12, 2)
  status          payment_status @default(PENDING)
  snapToken       String?        @map("snap_token")
  snapUrl         String?        @map("snap_url")
  vaNumber        String?        @map("va_number")
  qrCodeUrl       String?        @map("qr_code_url")
  paidAt          DateTime?      @map("paid_at") @db.Timestamptz(6)
  expiredAt       DateTime?      @map("expired_at") @db.Timestamptz(6)
  rawResponse     Json?          @map("raw_response")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod   String?        @default("QRIS") @map("payment_method") @db.VarChar(50)
  adminFee        Decimal?       @default(0) @map("admin_fee") @db.Decimal(12, 2)

  @@map("payments")
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  buyerUserId String?  @map("buyer_user_id") @db.Uuid
  supplierName String  @map("supplier_name")
  sender      String   // 'buyer' | 'supplier'
  text        String
  status      String   @default("sent")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  buyer       User?    @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum entry_status {
  ACTIVE
  MATCHED
  CLOSED
}

enum entry_type {
  SUPPLY
  DEMAND
}

enum match_status {
  PENDING
  MATCHED
  COMPLETED
  CANCELLED
}

enum order_status {
  MENUNGGU_PEMBAYARAN
  DIPROSES
  DIKIRIM
  SELESAI
  DIBATALKAN
}

enum user_role {
  PETANI
  PEDAGANG
  ADMIN
}

enum payment_status {
  PENDING
  CAPTURE
  SETTLEMENT
  DENY
  CANCEL
  EXPIRE
  REFUND
}

model PaymentGroup {
  id            String    @id @default(uuid()) @db.Uuid
  buyerUserId   String?   @map("buyer_user_id") @db.Uuid
  totalAmount   Decimal   @map("total_amount") @db.Decimal(12, 2)
  serviceFee    Decimal   @default(2000) @map("service_fee") @db.Decimal(12, 2)
  paymentMethod String?   @default("QRIS") @map("payment_method") @db.VarChar(50)
  status        String?   @default("PENDING") @db.VarChar(50)
  midtransOrderId String? @unique @map("midtrans_order_id") @db.VarChar(255)
  qrString      String?   @map("qr_string")
  vaNumber      String?   @map("va_number") @db.VarChar(100)
  expiredAt     DateTime? @map("expired_at") @db.Timestamptz(6)
  paidAt        DateTime? @map("paid_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  orders        Order[]

  @@map("payment_groups")
}

model SupplierDeliverySetting {
  id             String   @id @default(uuid()) @db.Uuid
  supplierUserId String   @map("supplier_user_id") @db.Uuid
  timeSlot       String   @map("time_slot") @db.VarChar(50)
  startTime      DateTime @map("start_time") @db.Time(6)
  endTime        DateTime @map("end_time") @db.Time(6)
  dailyCapacity  Int      @default(10) @map("daily_capacity")
  isEnabled      Boolean  @default(true) @map("is_enabled")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([supplierUserId, timeSlot])
  @@map("supplier_delivery_settings")
}

model SupplierBlockedDate {
  id             String   @id @default(uuid()) @db.Uuid
  supplierUserId String   @map("supplier_user_id") @db.Uuid
  blockedDate    DateTime @map("blocked_date") @db.Date
  reason         String?  @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([supplierUserId, blockedDate])
  @@map("supplier_blocked_dates")
}

model NotificationQueue {
  id             String    @id @default(uuid()) @db.Uuid
  type           String    @db.VarChar(50)
  recipientPhone String    @map("recipient_phone") @db.VarChar(20)
  message        String
  status         String?   @default("PENDING") @db.VarChar(50)
  attempts       Int?      @default(0)
  lastAttemptAt  DateTime? @map("last_attempt_at") @db.Timestamptz(6)
  errorMessage   String?   @map("error_message")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_queue")
}

model Review {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String   @unique @map("order_id")
  buyerUserId  String?  @map("buyer_user_id") @db.Uuid
  supplierName String   @map("supplier_name")
  rating       Int      // 1-5
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
